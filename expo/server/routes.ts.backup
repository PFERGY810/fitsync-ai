        sugar: 0.7,
        source: "usda",
      },
      {
        name: "Oatmeal (cooked)",
        servingSize: 234,
        servingUnit: "g",
        calories: 158,
        protein: 6,
        carbs: 27,
        fat: 3.2,
        fiber: 4,
        sugar: 1.1,
        source: "usda",
      },
      {
        name: "Sweet Potato (baked)",
        servingSize: 200,
        servingUnit: "g",
        calories: 180,
        protein: 4,
        carbs: 41,
        fat: 0.2,
