        front: photos?.front
          ? `${photos.front.substring(0, 50)}... (${photos.front.length} chars)`
          : "none",
        side: photos?.side
          ? `${photos.side.substring(0, 50)}... (${photos.side.length} chars)`
          : "none",
        back: photos?.back
          ? `${photos.back.substring(0, 50)}... (${photos.back.length} chars)`
          : "none",
